PORT=8080
APP_ENV=local

# PostgreSQL
POSTGRES_DSN=postgres://user:password@localhost:5432/qwikkle?sslmode=disable

# MongoDB
MONGO_URI=mongodb://localhost:27017

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Soketi / real-time
SOKETI_APP_ID=your-app-id
SOKETI_APP_KEY=your-app-key
SOKETI_APP_SECRET=your-app-secret
SOKETI_HOST=http://localhost:6001

# Auth / JWT
JWT_ACCESS_SECRET=replace-with-secure-random-string
JWT_REFRESH_SECRET=replace-with-secure-random-string

# Storage provider
#
# Supported:
# - s3: AWS S3 or any S3-compatible storage (including Cloudflare R2)
# - minio: MinIO (S3-compatible, usually via S3_ENDPOINT)
# - vercel_blob: Vercel Blob (upload happens elsewhere; backend only registers metadata)
STORAGE_PROVIDER=s3

# S3 / MinIO (used when STORAGE_PROVIDER is s3 or minio)
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Vercel Blob (used when STORAGE_PROVIDER is vercel_blob)
# Upload the file using Vercel (web) and then call POST /uploads/register with provider=vercel_blob.
# No S3_* vars are required for the API in this mode.
BLOB_READ_WRITE_TOKEN=

# Push notifications (future)
FCM_SERVER_KEY=replace-me
APNS_KEY_ID=replace-me
APNS_TEAM_ID=replace-me

# Voice / video (future)
AGORA_APP_ID=replace-me
AGORA_APP_CERTIFICATE=replace-me
